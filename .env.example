# ============================================================
#  Environment variable template — Food Ordering System
#  Copy this file to .env and fill in real values:
#    cp .env.example .env
#  Or generate secure secrets automatically:
#    ./generate-secrets.sh
#
#  .env is gitignored and must NEVER be committed.
#  In production/cloud, set these variables in your platform's
#  secrets manager instead of using a .env file.
# ============================================================

# --- JWT ---
# 256-bit hex-encoded secret shared between user-service and gateway-service.
# Generate with:  openssl rand -hex 32
JWT_SECRET=replace-me-with-output-of-openssl-rand-hex-32

# --- Database ---
POSTGRES_USER=user
POSTGRES_PASSWORD=password

# --- Redis ---
REDIS_HOST=redis-cache
REDIS_PORT=6379
