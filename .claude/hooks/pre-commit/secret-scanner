#!/usr/bin/env bash
# Runs gitleaks against staged content. Fail-open if gitleaks is not installed.
set -euo pipefail

if ! command -v gitleaks >/dev/null 2>&1; then
  echo "WARNING: gitleaks not installed — secret scan skipped. Install: https://github.com/gitleaks/gitleaks"
  exit 0
fi

gitleaks protect --staged --no-banner --redact 2>&1
EXIT=$?

if [ $EXIT -eq 1 ]; then
  echo ""
  echo "Secret detected in staged changes."
  echo "If this is a false positive, add the path to .gitleaks.toml with a justification comment."
  exit 1
fi
exit 0
