<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

    <!-- Read app name from Spring config so Loki labels are accurate -->
    <springProperty scope="context" name="appName" source="spring.application.name" defaultValue="user-service"/>

    <!-- Console: colored output for local reading -->
    <property name="CONSOLE_PATTERN"
              value="%clr(%d{HH:mm:ss.SSS}){faint} %clr(%5p) %clr(---){faint} [%15.15t] %clr(%-40.40logger{39}){cyan} : %clr([traceId=%X{traceId:-none}, spanId=%X{spanId:-none}]){yellow} %m%n${LOG_EXCEPTION_CONVERSION_WORD:-%wEx}"/>

    <!-- Loki: plain text — no ANSI codes, structured enough to query in Grafana -->
    <property name="LOKI_PATTERN"
              value="%d{yyyy-MM-dd HH:mm:ss.SSS} %5p [${appName}] [%t] traceId=%X{traceId:-none} spanId=%X{spanId:-none} logger=%logger{36} | %m%n${LOG_EXCEPTION_CONVERSION_WORD:-%wEx}"/>

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${CONSOLE_PATTERN}</pattern>
        </encoder>
    </appender>

    <appender name="LOKI" class="com.github.loki4j.logback.Loki4jAppender">
        <http>
            <url>http://loki:3100/loki/api/v1/push</url>
        </http>
        <format>
            <label>
                <!-- Query in Grafana by: {app="user-service"} or {app="user-service", level="ERROR"} -->
                <pattern>app=${appName},level=%level</pattern>
            </label>
            <message>
                <pattern>${LOKI_PATTERN}</pattern>
            </message>
            <sortByTime>true</sortByTime>
        </format>
    </appender>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="LOKI"/>
    </root>
</configuration>
